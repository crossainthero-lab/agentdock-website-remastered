{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "dev:pages": "npm run build && npx wrangler pages dev dist",
    "deploy": "npm run build && npx wrangler pages deploy dist",
    "test": "npm run test:waitlist && npm run test:cms && npm run test:content-import",
    "test:waitlist": "tsx tests/waitlist.test.ts",
    "test:cms": "tsx tests/cms.test.ts",
    "test:content-import": "tsx tests/content-import.test.ts",
    "admin:credentials": "tsx scripts/generate-admin-credentials.ts",
    "cf:typegen": "npx wrangler types",
    "db:migrate:local": "npx wrangler d1 migrations apply agentdock-waitlist --local",
    "db:migrate:remote": "npx wrangler d1 migrations apply agentdock-waitlist --remote",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dompurify": "^3.4.12",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "lucide-react": "^0.546.0",
    "marked": "^18.0.7",
    "mermaid": "^11.16.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wrangler": "^4.113.0"
  }
}
